{
  "name": "round-table",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/copy-personas.mjs && vite",
    "build": "node scripts/copy-personas.mjs && tsc -b && vite build",
    "preview": "vite preview",
    "backend:dev": "npm run dev --prefix backend",
    "dev:all": "concurrently -n backend,frontend -c blue,green \"npm run backend:dev\" \"cross-env VITE_API_URL=http://localhost:3001/api npm run dev\"",
    "backend:build": "cd backend && npm run build",
    "backend:deploy": "cd backend && npx cdk deploy --require-approval never"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "typescript": "~5.6.2",
    "vite": "~6.0.1"
  }
}
